FROM php:8.1-cli

# Install base dependencies
RUN apt-get update && apt-get install -y \
    unzip \
    supervisor \
    ca-certificates \
    curl \
    gnupg \
    libpng-dev \
    libjpeg62-turbo-dev \
    libfreetype6-dev \
    libwebp-dev \
    libzip-dev \
    libxml2-dev \
    libldap2-dev \
 && apt-get clean && rm -rf /var/lib/apt/lists/*

# Copy Fortinet certificate into container
COPY ./Fortinet_CA_SSL.cer /usr/local/share/ca-certificates/Fortinet_CA_SSL.crt
RUN chmod 644 /usr/local/share/ca-certificates/Fortinet_CA_SSL.crt \
 && update-ca-certificates

# Install PHP extensions
RUN docker-php-ext-configure gd --with-freetype --with-jpeg --with-webp \
 && docker-php-ext-install gd pdo_mysql mysqli zip soap ldap \
 && pecl install apcu \
 && docker-php-ext-enable apcu

# PHP config
RUN { \
    echo "max_execution_time = 300"; \
    echo "memory_limit = 512M"; \
    echo "max_input_vars = 3000"; \
    echo "post_max_size = 100M"; \
    echo "upload_max_filesize = 100M"; \
    echo "max_file_uploads = 50"; \
} >> /usr/local/etc/php/php.ini

# Composer
RUN curl -sS https://getcomposer.org/installer | php -- \
    --install-dir=/usr/local/bin --filename=composer

# Node & npm
RUN apt-get update \
 && apt-get install -y nodejs npm \
 && npm install -g npm@latest \
 && rm -rf /var/lib/apt/lists/*

# Workdir
WORKDIR /app

# Add non-root user
RUN adduser --uid 1000 --disabled-password --gecos "" user \
 && chown -R user:user /app
USER user

# COPY source code later in docker-compose bind mount or here if needed
# COPY . .

# Supervisor config
COPY ../docker/supervisord.conf /etc/supervisor/supervisord.conf

EXPOSE 8000
CMD ["/usr/bin/supervisord"]



